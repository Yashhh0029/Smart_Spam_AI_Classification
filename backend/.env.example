# ──────────────────────────────────────────────────────────────────────────────
# Smart Spam AI – Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# JWT signing secret – change this in production!
AUTH_SECRET=change-me-to-a-long-random-string

# ─── SMTP (email notifications) ───────────────────────────────────────────────
# To enable email notifications (welcome email on register, alert on login):
#   1. Use a Gmail account
#   2. Enable 2-Step Verification on that account
#   3. Go to: Google Account → Security → App Passwords
#   4. Generate an App Password for "Mail"
#   5. Paste it as SMTP_PASS below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-gmail@gmail.com

# ─── Optional: Google OAuth for Gmail inbox scanning ─────────────────────────
# (handled in frontend/.env — set VITE_GOOGLE_CLIENT_ID there)
